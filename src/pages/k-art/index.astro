---
<BaseLayout title="K-art">
  <h1>K-art</h1>
  <p style="margin-top: 1rem; max-width: 520px; margin-bottom: 2.5rem;">
    A collection of works.
  </p>

  <div class="art-grid">
    {images.map((filename) => {
      const slug = filename.replace(/\.[^.]+$/, '');
      return (
        <a href={`/k-art/${slug}`} class="art-thumb">
          <img src={`/k-art/${filename}`} alt={filename} loading="lazy" />
        </a>
      );
    })}
  </div>
</BaseLayout>

<style>
  .art-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
  }
  .art-thumb {
    display: block;
    overflow: hidden;
    border-radius: 6px;
    border: 1px solid var(--border);
    aspect-ratio: 1;
    transition: transform 0.15s, border-color 0.15s;
  }
  .art-thumb:hover {
    transform: translateY(-2px);
    border-color: var(--teal);
  }
  .art-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
